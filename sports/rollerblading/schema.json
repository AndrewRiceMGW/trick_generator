{
  "metadata": {
    "name": "Aggressive Inline Skating Trick Generator Schema",
    "version": "1.0",
    "description": "Complete data model for generating valid aggressive inline skating tricks",
    "notes": {
      "spin_direction": "Spins can be done as 'true spin' (out-spin, spinning away from obstacle) or 'alley-oop' (in-spin, spinning into obstacle). Alley-oop is harder and uses alleyoop_difficulty value. Spin direction depends on approach angle and obstacle side.",
      "topside_tricks": "Topside variations involve bending over the side of the obstacle (soul tricks done with different body position). These add complexity to switch-ups.",
      "switch_up_combinations": "Advanced skaters can switch up while spinning, which significantly increases difficulty."
    }
  },
